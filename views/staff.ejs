<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Maintenance Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
body { margin:0; font-family:'Poppins'; background:#f4f6f9; }

/* Sidebar */
.sidebar {
    width:240px; height:100vh; position:fixed;
    background:#0d2c54; color:white;
}
.sidebar h4 { padding:20px; }
.sidebar a {
    display:block; padding:12px 20px;
    color:#ddd; text-decoration:none; cursor:pointer;
}
.sidebar a:hover { background:#1c3d6e; }

/* Main */
.main { margin-left:240px; padding:20px; }

/* Cards */
.card-box { padding:20px; border-radius:10px; background:#e9ecef; text-align:center; }
.card-green { background:#d4edda; }

/* Status */
.pending {background:#f6c23e;padding:5px 10px;border-radius:8px;}
.progress {background:#4e73df;color:white;padding:5px 10px;border-radius:8px;}
.done {background:#1cc88a;color:white;padding:5px 10px;border-radius:8px;}
.rejected {background:#e74a3b;color:white;padding:5px 10px;border-radius:8px;}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
<h4>HCMTS</h4>
<a onclick="showSection('dashboard')">Dashboard</a>
<a onclick="showSection('tasks')">My Tasks</a>
<a onclick="logout()">Logout</a>
</div>

<!-- MAIN -->
<div class="main">

<!-- TOPBAR -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Maintenance Staff Dashboard</h3>
    
    <div class="d-flex align-items-center">
        <!-- Notifications Toggle -->
        <div class="dropdown me-3">
            <button class="btn btn-outline-dark btn-sm position-relative" type="button" data-bs-toggle="dropdown" onclick="markAllNotificationsRead()">
                <i class="fa fa-bell"></i>
                <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end p-2" style="width: 300px; max-height: 400px; overflow-y: auto;">
                <li><h6 class="dropdown-header">Notifications</h6></li>
                <li><hr class="dropdown-divider"></li>
                <div id="notifItems">
                    <li class="text-center p-3 text-muted">No notifications</li>
                </div>
            </ul>
        </div>

        <span id="staffNameDisplay" class="badge bg-dark me-2"></span>
        <button class="btn btn-sm btn-light" onclick="logout()">Logout</button>
    </div>
</div>

<!-- DASHBOARD -->
<div id="dashboard">
<h4>Welcome, <span id="welcomeName">Staff</span></h4>

<div class="row mt-3">
<div class="col-md-6">
<div class="card-box">
<h3 id="progressCount">0</h3>
<p>In Progress</p>
</div>
</div>

<div class="col-md-6">
<div class="card-box card-green">
<h3 id="completedCount">0</h3>
<p>Completed Objects</p>
</div>
</div>
</div>
</div>

<!-- TASKS -->
<div id="tasks" style="display:none;">
<h5>My Assigned Tasks</h5>

<div class="bg-white p-3 rounded mt-3">
<table class="table">
<thead>
<tr>
<th>ID</th>
<th>Date</th>
<th>Block</th>
<th>Room</th>
<th>Issue</th>
<th>Description</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>
<tbody id="taskTable"></tbody>
</table>
</div>
</div>

</div>

<script>
const token = localStorage.getItem('token');
const user = JSON.parse(localStorage.getItem('user'));

if(!token || user.role !== 'staff') { window.location.href = '/'; }

document.getElementById('staffNameDisplay').innerText = user.username;
document.getElementById('welcomeName').innerText = user.username;

function logout() { localStorage.clear(); window.location.href = '/'; }

function showSection(id) {
    document.querySelectorAll("#dashboard,#tasks").forEach(d => d.style.display = "none");
    document.getElementById(id).style.display = "block";
    if(id === 'tasks') loadTasks();
}

async function loadTasks() {
    const res = await fetch('/api/complaints', { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await res.json();
    if(data.success) {
        renderTasks(data.complaints);
        updateStats(data.complaints);
    }
}

function updateStats(complaints) {
    const progress = complaints.filter(c => c.status === 'In Progress').length;
    const completed = complaints.filter(c => c.status === 'Resolved').length;
    document.getElementById('progressCount').innerText = progress;
    document.getElementById('completedCount').innerText = completed;
}

function renderTasks(complaints) {
    const table = document.getElementById('taskTable');
    table.innerHTML = "";

    complaints.forEach(c => {
        const date = new Date(c.createdAt).toLocaleDateString();
        const snippet = c.description.substring(0, 30) + (c.description.length > 30 ? '...' : '');

        table.innerHTML += `
        <tr>
            <td>${c.id}</td>
            <td>${date}</td>
            <td>${c.block}</td>
            <td>${c.room_no_no}</td>
            <td>${c.complaint_type}</td>
            <td><small>${snippet}</small></td>
            <td>
                <select class="form-select form-select-sm" onchange="updateStaffStatus(${c.id}, this.value)">
                    <option value="In Progress" ${c.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                    <option value="Resolved" ${c.status === 'Resolved' ? 'selected' : ''}>Resolved</option>
                    <option value="Rejected" ${c.status === 'Rejected' ? 'selected' : ''} disabled>Rejected</option>
                </select>
            </td>
            <td>
                <span class="badge ${getStatusClass(c.status)}">${c.status}</span>
            </td>
        </tr>`;
    });
}

function getStatusClass(status) {
    if(status === 'Pending') return 'pending';
    if(status === 'In Progress') return 'progress';
    if(status === 'Resolved') return 'done';
    if(status === 'Rejected') return 'rejected';
    return '';
}

async function updateStaffStatus(id, newStatus) {
    const res = await fetch(`/api/complaints/${id}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ status: newStatus })
    });
    if((await res.json()).success) { loadTasks(); }
}

async function resolveComplaint(id) {
    const res = await fetch(`/api/complaints/${id}/resolve`, {
        method: 'PUT',
        headers: { 'Authorization': `Bearer ${token}` }
    });
    if((await res.json()).success) { loadTasks(); }
}

loadTasks();

const loadNotifications = async () => {
    try {
        const res = await fetch('/api/notifications', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if(data.success) {
            const items = document.getElementById('notifItems');
            const unread = data.notifications.filter(n => !n.is_read).length;
            
            if(unread > 0) {
                document.getElementById('notifBadge').innerText = unread;
                document.getElementById('notifBadge').style.display = 'block';
            } else {
                document.getElementById('notifBadge').style.display = 'none';
            }

            if(data.notifications.length === 0) {
                items.innerHTML = '<li class="text-center p-3 text-muted">No notifications</li>';
                return;
            }

            items.innerHTML = data.notifications.map(n => `
                <li class="p-2 border-bottom ${!n.is_read ? 'bg-light font-weight-bold' : ''}">
                    <div style="font-size: 0.85rem;">${n.message}</div>
                    <small class="text-muted" style="font-size: 0.7rem;">${new Date(n.createdAt).toLocaleString()}</small>
                </li>
            `).join('');
        }
    } catch (err) { console.error(err); }
};

const markAllNotificationsRead = async () => {
    try {
        const res = await fetch('/api/notifications', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if(data.success) {
            for(let n of data.notifications) {
                if(!n.is_read) {
                    await fetch(`/api/notifications/${n.id}`, {
                        method: 'PUT',
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                }
            }
            setTimeout(loadNotifications, 500);
        }
    } catch (err) { console.error(err); }
};

loadNotifications();
setInterval(loadNotifications, 120000);
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
